{
  "name": "qmims",
  "version": "0.1.1",
  "description": "AI-Powered README Generation & Editing using Kiro CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qmims": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && pnpm run copy-templates",
    "copy-templates": "node scripts/copy-templates.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:lenient": "jest --testPathIgnorePatterns=dist --passWithNoTests",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "readme",
    "kiro-cli",
    "documentation"
  ],
  "author": "Wassim Soltani",
  "license": "MIT",
  "packageManager": "pnpm@10.6.5",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.17",
    "@types/prompts": "^2.4.9",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "conf": "^10.2.0",
    "execa": "^5.1.1",
    "fs-extra": "^11.2.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2",
    "yargs": "^17.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=5.0.0 <5.1.7": ">=5.1.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "picomatch@<2.3.2": ">=2.3.2"
    }
  }
}
